# ───────────────────────────────────────────────────
# DeepaBMS Backend — Environment Configuration
# ───────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to version control.
# ───────────────────────────────────────────────────

## REQUIRED — Backend will fail to start without these

# Secret key used to sign and verify JWT authentication tokens.
# Generate a strong random key:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   openssl rand -base64 64
JWT_SECRET=change_me_to_a_random_64_byte_hex_string

# JWT issuer and audience claims (optional, validated on every request)
JWT_ISSUER=deepa-bms
JWT_AUDIENCE=deepa-bms-api

## OPTIONAL — Safe defaults exist

# Port the backend API server listens on (default: 3000)
PORT=3000

# Application environment: development | test | staging | production
NODE_ENV=development

# Path to the SQLite database file (default: ./deepa-bms.db)
# In Docker, this is typically /app/data/deepa-bms.db
SQLITE_DB_PATH=./deepa-bms.db

# Set to "true" to auto-start a Cloudflare Quick Tunnel on boot
START_TUNNEL=false

# Trust proxy setting for Express (default: loopback in dev, loopback+linklocal+uniquelocal in prod)
# Set to the reverse proxy IP or CIDR range that sits in front of the backend
TRUST_PROXY=loopback,linklocal,uniquelocal

# Comma-separated list of allowed CORS origins
# Default allows: localhost:3000 (dev server), localhost:8081 (Expo), localhost:19006 (Expo web)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

