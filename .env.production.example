# =============================================================================
# DeepaBMS — Production Environment Configuration
# =============================================================================
# Copy to .env.production and fill in all values before deploying.
#   cp .env.production.example .env.production
# NEVER commit .env.production to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=true
CORS_ORIGINS=https://your-domain.com

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_byte_hex_string
JWT_ISSUER=deepa-bms
JWT_AUDIENCE=deepa-bms-api

# ── SQLite ───────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=/app/data/deepa-bms.db

# ── Backups ──────────────────────────────────────────────────────────────────
ENABLE_BACKUP_CRON=true
BACKUP_S3_BUCKET=deepa-bms-backups
BACKUP_AWS_REGION=us-east-1

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@your-domain.com
SMTP_PASS=change_me

# ── Observability ────────────────────────────────────────────────────────────
METRICS_ENABLED=true
# SENTRY_DSN=https://xxx@o123456.ingest.sentry.io/1234567

# Grafana (required only when deploying with --profile monitoring)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_to_a_strong_grafana_password
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Cloudflare ───────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=eyJ...
