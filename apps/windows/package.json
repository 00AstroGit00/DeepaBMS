{
  "name": "deepa-bms-desktop",
  "version": "1.0.0",
  "description": "Windows native desktop installer wrapper for Deepa BMS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prepackage": "node fix-paths.js",
    "package": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^29.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.deepa.bms",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
