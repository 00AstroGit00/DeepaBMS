{
  "name": "deepa-bms-desktop",
  "version": "2.0.0",
  "description": "Deepa BMS – Hotel Management System (Desktop)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prepackage": "node fix-paths.js",
    "package": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.deepa.bms.desktop",
    "productName": "Deepa BMS",
    "win": {
      "target": [
        "nsis",
        "msi"
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Deepa BMS",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "msi": {
      "oneClick": false,
      "warningsAsErrors": false
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "fix-paths.js",
      "desktop.css",
      "web/**/*",
      "assets/**/*"
    ]
  }
}
