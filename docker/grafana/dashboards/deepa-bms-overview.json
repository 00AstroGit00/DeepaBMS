{
  "id": null,
  "uid": "deepa-bms-overview",
  "title": "DeepaBMS \u2014 Overview",
  "description": "System, backend, database, business, Redis and alert health for DeepaBMS.",
  "tags": [
    "deepabms",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": true,
  "theme": "dark",
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Timeseries",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "env",
        "type": "query",
        "query": "label_values(up, environment)",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "label": "Environment",
        "current": {
          "text": "production",
          "value": "production"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(node_uname_info, instance)",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "label": "Instance",
        "current": {},
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "System",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 101,
      "title": "CPU Usage %",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$instance\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 102,
      "title": "Memory Usage %",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"}) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 103,
      "title": "Disk Usage %",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay\"}) * 100",
          "legendFormat": "{{instance}} / {{mountpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 104,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=~\"$instance\",device!~\"lo\"}[5m])",
          "legendFormat": "rx {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=~\"$instance\",device!~\"lo\"}[5m])",
          "legendFormat": "tx {{device}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 200,
      "title": "Backend",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "collapsed": false
    },
    {
      "id": 201,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"backend\",env=~\"$env\"}[5m])) by (method)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 202,
      "title": "Latency p50/p95/p99",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{service=\"backend\",env=~\"$env\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{service=\"backend\",env=~\"$env\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{service=\"backend\",env=~\"$env\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ]
    },
    {
      "id": 203,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"backend\",env=~\"$env\",status=~\"5..\"}[5m])) by (path)",
          "legendFormat": "5xx {{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 204,
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "deepa_bms_backend_connections{env=~\"$env\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 300,
      "title": "Database",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "collapsed": false
    },
    {
      "id": 301,
      "title": "Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{env=~\"$env\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 302,
      "title": "Queries/sec",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"deepabms\",env=~\"$env\"}[5m]) + rate(pg_stat_database_xact_rollback{datname=\"deepabms\",env=~\"$env\"}[5m])",
          "legendFormat": "tps",
          "refId": "A"
        }
      ]
    },
    {
      "id": 303,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"deepabms\",env=~\"$env\"} / (pg_stat_database_blks_hit{datname=\"deepabms\",env=~\"$env\"} + pg_stat_database_blks_read{datname=\"deepabms\",env=~\"$env\"}) * 100",
          "legendFormat": "hit %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 304,
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "pg_replication_lag_seconds{env=~\"$env\"}",
          "legendFormat": "lag (s)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 400,
      "title": "Business",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "collapsed": false
    },
    {
      "id": 401,
      "title": "Revenue",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 52
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "deepa_bms_revenue_total{env=~\"$env\"}",
          "legendFormat": "revenue",
          "refId": "A"
        }
      ]
    },
    {
      "id": 402,
      "title": "Occupancy",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 52
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "deepa_bms_occupancy_ratio{env=~\"$env\"} * 100",
          "legendFormat": "occupancy %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 403,
      "title": "Restaurant Covers",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 60
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(deepa_bms_covers_total{env=~\"$env\"}[1h])) by (outlet)",
          "legendFormat": "{{outlet}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 404,
      "title": "Bar Sales",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 60
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(rate(deepa_bms_bar_sales_total{env=~\"$env\"}[1h])) by (category)",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 405,
      "title": "Inventory Turnover",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 68
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "deepa_bms_inventory_turnover{env=~\"$env\"}",
          "legendFormat": "turnover",
          "refId": "A"
        }
      ]
    },
    {
      "id": 406,
      "title": "Cash Flow",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 68
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "deepa_bms_cash_flow{env=~\"$env\"}",
          "legendFormat": "cash flow",
          "refId": "A"
        }
      ]
    },
    {
      "id": 500,
      "title": "Redis",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 76
      },
      "collapsed": false
    },
    {
      "id": 501,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 77
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{env=~\"$env\"}",
          "legendFormat": "used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 502,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 77
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total{env=~\"$env\"} / (redis_keyspace_hits_total{env=~\"$env\"} + redis_keyspace_misses_total{env=~\"$env\"}) * 100",
          "legendFormat": "hit %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 503,
      "title": "Connected Clients",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 85
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "redis_connected_clients{env=~\"$env\"}",
          "legendFormat": "clients",
          "refId": "A"
        }
      ]
    },
    {
      "id": 600,
      "title": "Alerts",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 93
      },
      "collapsed": false
    },
    {
      "id": 601,
      "title": "Active Alerts",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 94
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "sum(ALERTS{alertstate=\"firing\",env=~\"$env\"}) by (alertname,severity)",
          "legendFormat": "{{alertname}} ({{severity}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 602,
      "title": "Alert Count by Severity",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 94
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "count by (severity) (ALERTS{alertstate=\"firing\",env=~\"$env\"})",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    }
  ]
}